# grok-mcp production environment (ADR-0007)
#
# Install as /etc/grok-mcp/env, mode 0600.
# For local experiments: copy to .local/env (never commit).
#
# Dual-compatible: shell `set -a; . env; set +a` and systemd EnvironmentFile=.
# Single-quote values with spaces. No ${…} expansion at load time.

# --- transport ----------------------------------------------------------
GROK_MCP_TRANSPORT=http
GROK_MCP_LOG_FORMAT=json

# --- HTTP / front-door (cloudflared → loopback) -------------------------
# TLS ends at cloudflared; app listens on loopback only.
GROK_MCP_HTTP_ADDR=127.0.0.1:8765
# Must match the public hostname clients use (Host guard).
GROK_MCP_HTTP_ALLOWED_HOSTS=mcp.example.com
# Bearer for Claude Code AND the OAuth /authorize gate for claude.ai.
# Generate:  deploy/grokctl token
#        or: head -c 32 /dev/urandom | base64 | tr '+/' '-_' | tr -d '='
GROK_MCP_HTTP_TOKEN=REPLACE_ME
# OAuth issued-token store (survives restarts). Use an absolute path.
GROK_MCP_STATE_DIR=/home/YOUR_USER/.local/state/grok-mcp

# --- xAI SuperGrok credentials ------------------------------------------
# Run once as the service user:
#   grok-mcp auth import    # from ~/.grok/auth.json
#   # or: grok-mcp auth login
# Default store: ~/.config/grok-mcp/auth.json
# GROK_MCP_AUTH_FILE=/home/YOUR_USER/.config/grok-mcp/auth.json

# Pay-per-token API path is OFF by default.
# GROK_MCP_ALLOW_API_KEY=0
# XAI_API_KEY=

# --- model (optional) ---------------------------------------------------
# GROK_MCP_DEFAULT_MODEL=grok-4.5
# GROK_MCP_BASE_URL=https://api.x.ai/v1
